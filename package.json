{
  "name": "@freecodecamp/freecodecamp",
  "version": "0.0.1",
  "description": "The freeCodeCamp.org open-source codebase and curriculum",
  "license": "BSD-3-Clause",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freeCodeCamp/freeCodeCamp.git"
  },
  "bugs": {
    "url": "https://github.com/freeCodeCamp/freeCodeCamp/issues"
  },
  "homepage": "https://github.com/freeCodeCamp/freeCodeCamp#readme",
  "author": "freeCodeCamp <team@freecodecamp.org>",
  "main": "none",
  "scripts": {
    "audit-challenges": "pnpm turbo build --filter=@freecodecamp/shared && tsx tools/challenge-auditor/index.ts",
    "analyze-bundle": "webpack-bundle-analyzer",
    "prebuild": "pnpm turbo build --filter=@freecodecamp/shared",
    "build": "pnpm turbo build",
    "build-workers": "pnpm --filter=@freecodecamp/client run prebuild",
    "build:client": "pnpm --filter=@freecodecamp/client run build",
    "build:curriculum": "pnpm --filter=@freecodecamp/curriculum run build",
    "build:api": "pnpm --filter=@freecodecamp/api run build",
    "challenge-editor": "pnpm turbo start --filter=\"@freecodecamp/challenge-editor*\"",
    "clean": "pnpm turbo clean && pnpm run clean:packages",
    "clean-and-develop": "pnpm run clean && pnpm install && pnpm run develop",
    "clean:api": "pnpm --filter=@freecodecamp/api clean",
    "clean:client": "pnpm --filter=@freecodecamp/client run clean",
    "clean:curriculum": "rm -rf ./shared/config/curriculum.json",
    "clean:packages": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "create:shared": "tsc -p shared",
    "create-new-project": "pnpm --filter=@freecodecamp/curriculum-helper-scripts run create-project",
    "create-new-language-block": "pnpm --filter=@freecodecamp/curriculum-helper-scripts run create-language-block",
    "create-new-quiz": "pnpm --filter=@freecodecamp/curriculum-helper-scripts run create-quiz",
    "predevelop": "pnpm turbo run build:curriculum --filter=@freecodecamp/curriculum",
    "develop": "pnpm turbo develop",
    "develop:client": "pnpm --filter=@freecodecamp/client run develop",
    "develop:api": "pnpm --filter=@freecodecamp/api run develop",
    "format": "pnpm run format:eslint && pnpm run format:prettier",
    "format:eslint": "eslint . --fix",
    "format:prettier": "prettier --write .",
    "i18n-sync": "tsx ./tools/scripts/sync-i18n.ts",
    "knip": "npx -y knip@5 --include files",
    "knip:all": "npx -y knip@5 ",
    "prelint": "pnpm --filter=@freecodecamp/client run predevelop",
    "lint": "NODE_OPTIONS=\"--max-old-space-size=7168\" pnpm turbo lint",
    "lint:challenges": "pnpm --filter=@freecodecamp/curriculum run lint",
    "lint:js": "eslint --cache --max-warnings 0 .",
    "lint:ts": "tsc && tsc -p shared && tsc -p api && tsc -p client",
    "lint:prettier": "prettier --list-different .",
    "lint:css": "stylelint '**/*.css'",
    "preseed": "pnpm turbo build --filter=@freecodecamp/shared",
    "playwright:install-build-tools": "npx playwright install --with-deps",
    "rename-challenges": "tsx tools/challenge-helper-scripts/rename-challenge-files.ts",
    "seed": "pnpm seed:surveys && pnpm seed:exams && DEBUG=fcc:* node ./tools/scripts/seed/seed-demo-user",
    "seed:certified-user": "pnpm seed:surveys && pnpm seed:exams && pnpm seed:ms-username && DEBUG=fcc:* node ./tools/scripts/seed/seed-demo-user --certified-user",
    "seed:exams": "DEBUG=fcc:* node tools/scripts/seed-exams/create-exams",
    "seed:env-exam": "pnpm --filter=@freecodecamp/api run seed:env-exam",
    "seed:surveys": "DEBUG=fcc:* node ./tools/scripts/seed/seed-surveys",
    "seed:ms-username": "DEBUG=fcc:* node ./tools/scripts/seed/seed-ms-username",
    "serve:client": "pnpm --filter=@freecodecamp/client run serve",
    "serve:client-ci": "pnpm --filter=@freecodecamp/client run serve-ci",
    "start": "pnpm turbo run build --filter=@freecodecamp/shared && pnpm turbo run develop --filter=@freecodecamp/api serve --filter=@freecodecamp/client",
    "test": "NODE_OPTIONS='--max-old-space-size=7168' pnpm turbo test",
    "test:api": "pnpm --filter=@freecodecamp/api exec jest --force-exit",
    "test:client": "jest client",
    "test:curriculum": "pnpm --filter=@freecodecamp/curriculum test",
    "test:curriculum:js": "jest curriculum",
    "test:curriculum:full-output": "pnpm --filter=@freecodecamp/curriculum run test:full-output",
    "test:config": "jest config",
    "test:tools": "jest tools",
    "test:utils": "jest utils",
    "prepare": "husky",
    "playwright:run": "playwright test",
    "playwright:watch": "playwright test --ui-port=0"
  },
  "dependencies": {
    "dotenv": "16.4.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.26.5",
    "@babel/preset-react": "7.26.3",
    "@eslint/compat": "^1.2.6",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.47.1",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@types/jest": "29.5.12",
    "@types/lodash": "4.14.202",
    "@types/node": "20.12.8",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "8.24.0",
    "@typescript-eslint/parser": "8.23.0",
    "babel-jest": "29.7.0",
    "eslint": "9.19.0",
    "eslint-config-prettier": "10.0.1",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-filenames-simple": "0.9.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-jsdoc": "48.2.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-no-only-tests": "3.1.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "4.6.0",
    "eslint-plugin-testing-library": "7.1.1",
    "globals": "^15.14.0",
    "husky": "9.0.11",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "js-yaml": "3.14.1",
    "lint-staged": "^13.1.0",
    "lodash": "4.17.21",
    "markdownlint": "0.33.0",
    "prettier": "3.2.5",
    "prismjs": "1.29.0",
    "stylelint": "16.14.1",
    "tsx": "4.19.1",
    "turbo": "^2.5.5",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.23.0",
    "webpack-bundle-analyzer": "4.10.1",
    "yargs": "17.7.2"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react-scrollable-anchor>react": "17",
        "react-scrollable-anchor>react-dom": "17"
      }
    },
    "onlyBuiltDependencies": [
      "@freecodecamp/ui",
      "@prisma/client",
      "@prisma/engines",
      "core-js",
      "ejs",
      "es5-ext",
      "esbuild",
      "gatsby",
      "gatsby-cli",
      "gatsby-telemetry",
      "lmdb",
      "msgpackr-extract",
      "msw",
      "nodemon",
      "prisma",
      "puppeteer",
      "sharp"
    ]
  }
}
